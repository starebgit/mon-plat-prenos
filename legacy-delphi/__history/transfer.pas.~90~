Procedure TFtransfer.Getprenos ;
 var deln,sx, statdn,kdd : string ;
     order,pkod,conf,conf_c,mat,dm : string ;
     dn,kodpl,nzp,nzs,mt,nzz,mtp,mts,dir,mto,nzo,pzz : string ;
     vredu,bkod : boolean ;
     tab,tabc,tabs : variant ;
     ist,kk,izap,i,j,m,mm,ni : Integer ;
     ikolic,potr,yie,yield : Integer ;
     mk,ln,idc,ix,ii,kks : integer ;
     slist,zlist,splist,zplist,sslist,zslist,solist,zolist : Tlist ;
     ff : textfile ;
     tt : longint ;
     dstart : TdateTime ;
     izvedba : boolean ;
begin
  show ;
  AdoQuery2.Connection := AdoConnection1  ;
  try
    ADOQuery2.SQL.Clear ;
    ADOquery2.SQL.add('select * from plosce') ;
    AdoQuery2.Open;
    AdoQuery2.first;
    deln := AdoQuery2nalog.value ;
    AdoQuery2.Close ;
  except
     deln := '000004283286' ;
  end;
  deln := '000005223286' ;



 // Fzacetek.label2.Caption := 'Začetni delovni nalog ' + deln ;

  tt := GetTickCount ;
  Screen.Cursor := crHourGlass ;


  //Fizvedi.AdoQuery2.delete ;
  izvedba := false ;
  Prijava ;
  if Connection.LogOn(0,true) = true then  (* parameter "true" = SilentLogOn *)
  begin
    izvedba := true ;
    ADOQuery2.SQL.Clear ;
    ADOquery2.SQL.add('delete from plosce') ;
    ADOquery2.execSQL ;
    sleep(500) ;

    ADOQuery2.SQL.Clear ;
    ADOquery2.SQL.add('select * from plosce') ;
    AdoQuery2.Open;

        // preberem listo delovnih nalogov za plošče
    GetProdList(1,'',deln,tab,vredu ) ;
    if not vredu then
    begin
       showMessage('Napaka bri branju proizvidnjih nalogov') ;
       exit
    end ;

    kk := Tab.rowCount ;
    sx := 'Prenos plošč ' ;
    Progbegin(sx,kk) ;

    izap := 1 ;
    for i := 1 to kk do           // po vseh delovnih nalogin za plošče
    begin
      // if terminated then exit  ;
      ProgUpdate(sx,kk) ;

       // tehnično zaključene izločim
       statdn := copy(tab.value(i,42),1,4) ;
       if (statdn = 'TEHZ') or (statdn = 'ZAKL') then continue ;

       // izločim naloge ki ne pripadajo ploščam
       kdd := tab.value(i,5) ;
       if (kdd[9] <> '4') and (kdd[9] <> '3') and (kdd[9] <> '2') then continue ;

       potr :=  Round(Tab.value(i,18)) ;      // količina na nalogu
       order := Tab.value(i,1) ;
       dstart := Tab.value(i,14) ;

       // preberem( podatke iz delovnega naloga
       GetProdDetail(order,4,tabc,vredu) ;
       if not vredu then
       begin
         showMessage('Napaka bri branju enega proizvodnjega naloga') ;
         exit
       end ;

       ikolic := 0 ;
       for j := 1 to tabc.rowCount do        // po vseh operacijah
       begin
          pkod := tabc.value[j,12] ;
          bkod := (pkod = 'PP04') or (pkod = 'PP14') or (pkod = 'PP02') or (pkod = 'PP10') ;
          if bkod and (tabc.value[j,25] > 0) and (tabc.value[j,11] = '0010') then
          begin
            conf := Tabc.value(j,4) ;
            // za vsako operacijo preberem potrditve
            GetConfList(order,conf,tabs,vredu) ;
            if not vredu then
            begin
              showMessage('Napaka bri branju list potrditev') ;
              exit
            end ;

            // računanje donosa
            yield := 0 ;
            mm := tabs.rowcount ;
            for m := 1 to mm do
            begin
               conf_c := tabs.value(m,2) ;
               GetConfDetail(conf,conf_c,yie) ;
               yield := yield + yie;
            end;

            ikolic := potr-yield ;
            if ikolic > 0 then
            begin
              dm := Tabc.value(j,43) ;
              ist := Traks.IndexOf(dm) +1 ;
              mat := KodaForm(tab.value(i,5),SL,false) ;
              ZapisPlo(izap,ist,ikolic,order,mat,dstart);
              Inc(izap) ;
           end;
         end;
       end;
     for j := 1 to tabc.rowCount do tabc.DeleteRow ;
    end ;      // konec pregled pa vseh nalogih
  end ;
  AdoQuery2.Close ;
  traks.free ;

  slist := Tlist.create    ;
  zlist := Tlist.create    ;
  splist := Tlist.create    ;
  zplist := Tlist.create    ;
  sslist := Tlist.create    ;
  zslist := Tlist.create    ;
  sulist := Tlist.create    ;
  zulist := Tlist.create    ;
  svlist := Tlist.create    ;
  zolist := Tlist.create    ;
  solist := Tlist.create    ;
  zvlist := Tlist.create    ;
  //zvlist := Tlist.create    ;
//  Prijava ;
  ADOtable1.Open ;
  ADOQuery2.Open ;

  if Connection.LogOn(0,true) = true then  (* parameter "true" = SilentLogOn *)
  begin
     ni := ADOQuery2.RecordCount ;
     sx := 'Prenos šamotov ' ;
     Progbegin(sx,ni) ;

     ADOQuery2.First ;
     while not ADOQuery2.Eof  do      // po vseh delovnih nalogih za plošče
     begin
         mk := 0 ;
         ProgUpdate(sx,ni) ;

         // preberem podatke za en delovni nalog
         ln := ADOQuery2stev.Value ;
         dn := ADOQuery2nalog.Value ;
         kodpl := ADOQuery2koda.Value ;
         idc := ADOQuery2ident.Value ;
         ix := round(ADOQuery2kolicina.Value);

         GetProdDetail(dn,5,tabc,vredu) ;     // branje komponent
         if not vredu then
         begin
           showMessage('Napaka bri branju enega proizvodnjega naloga') ;
           exit
         end ;

         nzp := '' ;
         nzs := '' ;
         for ii := 1 to tabc.rowcount do
         begin
           pzz := tabc.value(ii,28) ;
           if pos('amot',pzz) > 0 then
           begin
             mt := tabc.value(ii,5) ;
             nzz := pzz;
           end;

           if pos('PROTEKTOR',pzz) > 0 then
           begin
             mtp := tabc.value(ii,5) ;
             nzp := pzz;
           end;

           if pos('SPONKA',pzz) > 0 then
           begin
             mts := tabc.value(ii,5) ;
             nzs := pzz;
           end;

           if (pos('OBRO',pzz) > 0) and (pos('PAKIRNI',pzz) = 0) and (length(trim(pzz)) < 12) then
           begin
             mto := tabc.value(ii,5) ;
             nzo := pzz;
           end;
         end;
         for ii := 1 to tabc.rowCount do tabc.DeleteRow ;
         kks := 1 ;

         Obdelajsamot(nzz,mt,kodpl,dn,ix,ln,idc,zlist,slist) ;
         if nzp <> '' then ObdelajPolIzd(nzp,mtp,kodpl,dn,ix,ln,idc,kks,zplist,splist) ;   // protektor
         if nzs <> '' then ObdelajPolIzd(nzs,mts,kodpl,dn,ix,ln,idc,kks,zslist,sslist) ;  // sponke
         if nzo <> '' then
         begin
           kks := TipObroca(nzo) ;
           ObdelajPolIzd(nzo,mto,kodpl,dn,ix,ln,idc,kks,zolist,solist) ;     // obrov
         end;

         ADOQuery2.Next ;
     end;  // konec pregled delovnih nalogov

     slist.Sort(@comparesam);
     Zaloge(1,slist,zlist) ;        // šamoti
     //zlist.Free ;
     pocisti1(zlist) ;

     Zaloge(2,splist,zplist) ;        // protektor
     //splist.Free ;
    // zplist.Free ;
     pocisti1(zplist) ;
     pocisti2(splist) ;

     Zaloge(3,sslist,zslist) ;        // sponke
    // sslist.Free ;
    // zslist.Free ;
     pocisti1(zslist) ;
     pocisti2(sslist) ;

     Zaloge(4,sulist,zulist) ;          // ulitki
     pocisti1(zulist) ;
     pocisti2(sulist) ;

     Zaloge(5,svlist,zvlist) ;
     pocisti1(zvlist) ;
     pocisti2(svlist) ;

     Zaloge(6,solist,zolist) ;          // obroči
     pocisti1(zolist) ;
     pocisti2(solist) ;

   {  zaloge_sp(slist,svlist) ;
     pocisti2(svlist) ;
     pocisti1(zvlist) ;   }
     pocisti2(slist) ;
   end;
   vsota ;
   sapFunctions1.RemoveAll ;
  dir := ExtractFilePath(application.exename) ;
  assignFile(ff,dir + 'zadnidat.txt') ;
  rewrite(ff) ;
  writeln(ff,dateTimeTostr(now)) ;
  CloseFile(ff) ;

  Zadnji.sql.clear ;
  Zadnji.SQL.Add('INSERT INTO Zadprenos(ZADNJI) VALUES (:DAT)') ;
  Zadnji.parameters[0].Value := now ;
  Zadnji.Parameters[0].Name := 'DAT' ;
  Zadnji.execSQL;


 // PostObdelava ;
  if izvedba then dodatek ;
  label1.Caption := 'Prenos je končan ' + inttoStr(gettickCount-tt) ;
  Progressbar1.Visible := false ;
  close ;
  //Connection.Logoff ;
  Screen.Cursor := crDefault ;
end;

procedure TFTransfer.Prijava;
begin
  if prija.upo = '' then FPrijavaSAP.getPrijava(prija) ;

  if trim(prija.upo) = 'rsg_rfc_1' then plant := '0401' else plant := '1061' ;
  Connection := SAPLogoncontrol1.newConnection;
  with prija do
  begin
    Connection.User              := trim(upo) ;
    Connection.System            := trim(sistem);
    Connection.Client            := trim(cli);
    Connection.ApplicationServer := trim(applic);
    Connection.SystemNumber      := IntTostr(sisnum) ;
    Connection.Password          := trim(ges);
    Connection.Language          := trim(jezik) ;
  end ;
end ;

