Procedure TFtransfer.ListaPrek(var list : Tlist) ;
  var ii : Integer ;
      prvic : boolean ;
      pp : ^prrk ;
begin
  ADOQuery5.SQL.Clear ;
  ADOquery5.SQL.add('select * from prekinitve') ;
  AdoQuery5.Open;
  AdoQuery5.First ;
  while not AdoQuery5.eof  do
  begin
    if AdoQuery5.Fieldbyname('dan').value >= date then
    begin
      prvic := true ;
      for ii := 0 to list.count-1 do
      begin
        pp := list[ii] ;
        if (pp^.dt = AdoQuery5.Fieldbyname('dan').value) and (pp^.trak = AdoQuery5.Fieldbyname('trak').value) and (pp^.izmena = AdoQuery5.Fieldbyname('izmena').value) then
        begin
          prvic := false ;
          pp^.stev :=  pp^.stev + (1 shl AdoQuery5.Fieldbyname('ura').value)
        end;
      end;
      if prvic then
      begin
        new(pp) ;
        pp^.dt := AdoQuery5.Fieldbyname('dan').value ;
        pp^.izmena := AdoQuery5.Fieldbyname('trak').value ;
        pp^.trak := AdoQuery5.Fieldbyname('izmena').value ;
        pp^.stev := (1 shl AdoQuery5.Fieldbyname('ura').value) ;
        list.Add(pp) ;
      end;
    end;
    AdoQuery5.next ;
  end;
  AdoQuery5.Close ;
end;

