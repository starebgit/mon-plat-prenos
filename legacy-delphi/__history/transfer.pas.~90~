Procedure TFTransfer.povecaj(var dd : TdateTime; var izm : Integer) ;
 begin
    case izm of
      1 :  izm := 2 ;
      2 :
          if getnocna(dd,ADOTable1stev.Value,3) then izm := 3
             else nasled(dd,izm) ;

      3 :
        begin
          nasled(dd,izm) ;
          izm := 1 ;
        end;
    end;
end;

Function TFtransfer.GetNocna(dd : TdateTime; istev : integer; iz : integer) : boolean ;
  var bb : boolean ;
      pp : ^prrn ;
      ii : Integer ;
begin
  bb := false ;
  if assigned(clist) then
  begin
    for ii := 0 to clist.count-1 do
    begin
      pp := clist[ii] ;
      if (pp^.trak = istev) and (pp^.dt = dd) and (pp^.izmena = iz) then
      begin
        bb := true ;
        break ;
      end;
    end;
  end;
  result := bb ;
end ;

