// dodajanje v listo (pol)izdelkov
Procedure TFtransfer.ZapisSk(mt : string; ix,rz : longint; var zlist: tlist) ;
  var pp : ^zalsam ;
      ii : Integer;
      nasel : boolean ;
begin
  new(pp) ;
