Procedure TfTransfer.PostObdelava ;
  var kl,ekl : integer ;
      kp : integer ;
      dan,dan1 : TdateTime ;
      izm,izm1 : integer ;
      povecaj : integer ;
      ii : integer ;
begin
  ADOQuery10.SQL.Clear ;
  ADOquery10.SQL.add('select * from spirale order by dan,izmena') ;
  AdoQuery10.Open;
  Adoquery10.First ;
  kp := 30000 ;
  kl := 0 ;
  ekl := 0 ;
  dan := Adoquery10.FieldByName('dan').Value ;
  izm := Adoquery10.FieldByName('izmena').Value ;
  povecaj := 0 ;
  while not adoquery10.eof do
  begin
    if kl > kp then
    begin
      inc(povecaj)  ;
      kl := 0
    end;
    if (dan <> Adoquery10.FieldByName('dan').Value) or (izm <> Adoquery10.FieldByName('izmena').Value) then
    begin
      dan := Adoquery10.FieldByName('dan').Value ;
      izm := Adoquery10.FieldByName('izmena').Value ;
      kl := ekl ;
      ekl := 0 ;
      if povecaj > 0 then povecaj := povecaj - 1 ;
    end;
    if povecaj > 0 then
    begin
      dan1 := dan ;
      izm1 := izm ;

      for ii := 1 to povecaj do
      begin
         if izm1 = 1 then
           izm1 := 2
        else
        begin
          izm1 := 1 ;
          dan1 := dan1 + 1
         end;
      end;

      // nasled(dan1,izm1) ;
      ekl := ekl + Adoquery10.FieldByName('razlika').Value ;
      Adoquery10.edit ;
      Adoquery10.FieldByName('dan').Value := dan1 ;
      Adoquery10.FieldByName('izmena').Value := izm1 ;
      Adoquery10.Post ;
    end;
    kl := kl + Adoquery10.FieldByName('razlika').Value ;
    Adoquery10.Next ;
  end;
end;

