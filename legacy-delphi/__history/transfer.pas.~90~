// popravljanje števila potreb v listi kombinacij
procedure TFtransfer.ZapisSup(mat: string; ix : longint; slist : tlist) ;
  var ii : integer ;
      pp : ^sams ;
begin
  for ii  := 0 to slist.count-1 do
  begin
    pp := slist[ii] ;
    if  (pp.mat_pl = mat) then
    begin
      pp^.kolic := pp^.kolic + ix ;
      break
    end;
  end;
end;

// zapis v listo kombinacij izdelka in polizdelka (ni nujno šamot)
Procedure TFtransfer.Zapissamot(kk,idc,ln : integer ;mt,kodpl,dn,nz : string; ix : longint; var slist: tlist) ;
  var ii : integer ;
      nas : boolean ;
      pp : ^sams ;
begin
  nas := false ;
  for ii  := 0 to slist.count-1 do
  begin
    pp := slist[ii] ;
    if (pp.mat = mt) and (pp.mat_pl = kodpl) then
    begin
      nas := true ;
      pp^.kolic := pp^.kolic + ix ;
      break
    end;
  end;
  if not nas then
  begin
    new(pp) ;
    pp^.iprem := kk ;
    pp^.ipl := idc ;
    pp^.linija := ln ;
    pp^.mat := mt ;
    pp^.mat_pl := kodpl ;
    pp^.nalog := dn ;
    pp^.naziv := nz ;
    pp^.kolic := ix ;
    pp^.pec := 0 ;
  //  pp^.razl := rz ;
    slist.add(pp)
  end;
end;

// zapiš šamtov  v listo izdelkov in listo kombinacij
procedure TFtransfer.Obdelajsamot(nzz,mt,kodpl,dn : string; ix,ln : longint; idc : integer; zlist,slist : Tlist) ;
  var nz,statdn,delns,mat : string ;
      kk,k1,k2,m,i : Integer ;
      bsam,vredu : boolean ;
      taba,funct,tabs : variant ;
      yi1,yi2,yie,rz,tt : longint ;
      fdate : Tdatetime ;
      st_potr,arbid : string;
begin
   nz := StringReplace(nzz,'Plo##a #amot','Plošča šamot',[]) ;
   kk := 4 ;
   if pos('šamot 220',nz) > 0 then kk := 1  ;
   if pos('šamot 180',nz) > 0 then kk := 2  ;
   if pos('šamot 145',nz) > 0 then kk := 3  ;
   if pos('šamot 80',nz) > 0 then kk := 4   ;
   if pos('šamot 110',nz) > 0 then kk := 4  ;
   if pos('šamot 115',nz) > 0 then kk := 4  ;

   mat := KodaForm(mt,SL,false) ;
   // poiščem delovne naloge šamotov
   sapFunctions1.RemoveAll ;
   bsam := preveriSam(mt,zlist) ;
   // če šamot še ni bil obdelan
   if bsam then
   begin
      tt := GettickCount ;
      GetProdList(2,mt,dn,taba,vredu) ;   // lista delovnih nalogov za šamot
      if taba.rowCount = 0 then GetProdList(2,mt,'',taba,vredu) ;

      if not vredu then
      begin
        showMessage('Napaka bri branju proizvidnjih nalogov') ;
        exit
      end ;

      k1 := Taba.rowCount ;
      yi1 := 0 ;
      yi2 := 0 ;
      for i := 1 to k1 do       // po vseh nalogih za določen šamot
      begin
         delns := taba.value(i,1) ;
         try
            fdate := StrTodate(taba.value(i,10)) ;
         except
            fdate := date - 20
         end;

         // izločim že zaključene
         try
           statdn := copy(taba.value(i,42),1,4) ;
         except
           statdn := 'TEHZ'
         end;
         if statdn = 'TEHZ' then continue ;
         tt := gettickCount ;
         // komponente (ulitke in špirale) obravnavam samo na zadnjem nalogu
         if i = k1 then obdelajUli(delns,mat,ix,ln,idc,kk) ;

         // preberem potrditve za določen nalog
         SAPFunctions1.Connection := Idispatch(Connection);
         funct := sapFunctions1.add('ZETA_RFC_READ_AFRU');
         Funct.EXPORTS('dday').VALUE := fdate ;
         Funct.EXPORTS('stnal').VALUE := delns;
         funct.call ;

         // računam donose na dveh različnih operacijah
         tabs := funct.TABLES.item('IT_AFRU');    // tabela rezultatov
         k2 := Tabs.rowCount ;
         for m := 1 to k2 do
         begin
            arbid := Tabs.value(m,9) ;
            st_potr := tabs.value(m,2) ;
            if (arbid >= '10004712') and (arbid <= '10004720')  then
            begin
               yie :=  Tabs.value(m,38);
               if Tabs.value(m,95) = 'X' then yie := -yie ;
               if (arbid >= '10004712') and (arbid <= '10004718')  then yi1 := yi1 + yie;
               if (arbid = '10004720') or (arbid = '10004719') then yi2 := yi2 + yie;
            end;
         end ;
       end;   // konec pregled nalogov šamotov
       rz := yi1 - yi2 ;      // razlika donosov dveh operacijah
       ZapisSk(mat,ix,rz,zlist) ;    // zapis v listo šamotov
    end else ZapisSup(mat,ix,sulist) ;
    ZapisSamot(kk,idc,ln,mat,kodpl,dn,nz,ix,slist) ;   // zapis v listo kombinacij
end ;

procedure TFtransfer.ObdelajPolIzd(nzp,mtp,kodpl,dn : string; ix,ln : longint; idc,kk : integer; zplist,splist : Tlist) ;
  var nz,statdn,delns,mat : string ;
      k1,k2,m,i : Integer ;
      bsam,vredu : boolean ;
      taba,funct,tabs : variant ;
      yi1,yi2,yie,rz : longint ;
      fdate : Tdatetime ;
      st_potr,arbid : string;
begin
//   sapFunctions1.RemoveAll ;
   bsam := preveriSam(mtp,zplist) ;
   // če polizdelek še ni bil obdelan
   if bsam then
   begin
      mat := KodaForm(mtp,SL,false) ;
      yie := 0 ;
      ZapisSk(mat,ix,yie,zplist) ;
    end;

    mat := KodaForm(mtp,SL,false) ;
    ZapisSamot(kk,idc,ln,mat,kodpl,dn,nzp,ix,splist) ;
end ;

