// Obravnava zalog polizdelkov
Procedure TFtransfer.zaloge(opr : integer;slist,zlist : tlist) ;
   var funct1, funct2 : variant ;
       dn,tx,mat,mtt,mtz : string ;
       ix,sx,rx,iy,iz,ux,kp,xx : Longint ;
       ii,jj,id,jx,zx,zlx,zl : integer ;
       pp : ^zalsam ;
       p1 : ^sams ;
       tt : longint ;
       dd : TdateTime ;
       izm : integer;
       pro : ^prems ;
       kkd : string ;
       ids : integer ;
begin
  Prijava ;
  if Connection.LogOn(0,true) = true then  (* parameter "true" = SilentLogOn *)
  begin
    tx := intTostr(opr) + ' Prenos zalog ' + IntToStr(opr) + ' ' ;
    ProgBegin(tx,zlist.Count) ;

    // računanje zalog polizdelka
    for ii := 0 to zlist.Count-1 do    // po vseh kodah polizdelka
    begin
      ProgUpdate('A'+tx, zlist.Count) ;
      pp := zlist[ii] ;
      dn := pp^.mat ;
      mat := koda18(trim(dn)) ;
      pp^.zal := ZalogeZaMat(mat)  ;
    end;

    for jj  := 0 to zlist.count-1 do     // še enkrat po polizdelkih
    begin
      pp := zlist[jj] ;
      dn := pp^.mat ;
      ix := pp^.zal ;

      for ii  := 0 to slist.count-1 do        // po vseh kombinacijah izdelka in polizdelka
      begin
        p1 := slist[ii] ;
        if p1^.mat = dn then
        begin
          rx := p1.kolic - pp^.zal ;
          if rx > 0 then           // če so potrebe večje od zaloge
          begin
            p1^.zal := pp^.zal ;
            pp^.zal := 0 ;
            if rx > pp^.pec then
            begin
              p1^.pec := pp^.pec ;
              pp^.pec := 0
            end else
            begin
              p1^.pec := rx ;
              pp^.pec := pp^.pec - rx ;
            end;
          end else
          begin                                // zaloge so večje od potreb
            p1.zal :=  p1^.kolic;
            pp^.zal := pp^.zal- p1^.kolic
          end;
        end;
      end ;
    end;
  end;

  ProgBegin(tx,slist.Count) ;
  case opr of
    1 :                                            // šamoti
    begin
      tx := 'Zapis šamotov ' ;
      tt := GettickCount ;

      ADOQuery4.SQL.Clear ;
      ADOquery4.SQL.add('delete from samoti') ;
      ADOquery4.execSQL ;

      ADOQuery4.SQL.Clear ;
      ADOquery4.SQL.add('select * from samoti') ;
      AdoQuery4.Open;

      ADOQuery3.SQL.Clear ;
      ADOquery3.SQL.add('select * from premerSam') ;
      AdoQuery3.Open;

      AdoQuery3.First ;
      while Not AdoQuery3.Eof  do
      begin
        try
          AdoQuery3.edit ;
          AdoQuery3.FieldByname('vsota').value := 0 ;
          AdoQuery3.Post ;
        except
          //SHowMessage('Problem pri računanju vsote šamotov')
        end;
        AdoQuery3.Next ;
      end;
      for ii  := 0 to slist.count-1 do        // po vseh kombinacijah plošče in šamota
      begin
        ProgUpdate(tx,slist.count) ;
        p1 := slist[ii] ;

        ix := p1^.kolic - p1^.zal ;
        if p1^.pec > 0 then iz := p1^.pec else iz := 0 ;

        iy := ix - iz ;
        sx := sx + ix ;
       // if p1^.pec < 0 then Showmessage(p1^.mat) ;
        sleep(100) ;
        ZapisSam(p1^.iprem,p1^.linija,p1^.mat,p1^.mat_pl,p1^.naziv,p1^.kolic,p1^.zal,p1^.pec,ix,iy) ;

        id := p1^.iprem  ;
        if ADOQuery3.Locate('zap',id,[]) then
        begin
          try
            ADOQuery3.edit ;
            ux := ADOQuery3.FieldByname('vsota').value ;
            ADOQuery3.FieldByname('vsota').value := ux + ix ;
            ADOQuery3.Post ;
          except
           // on e: exception do Showmessage(E.message) ;
            // SHowMessage('Problem pri računanju vsote šamotov')
          end;
        end;
      end;
      ADOQuery4.Close ;
      ADOQuery3.Close ;
    end;
    2 :                                            // protektor
    begin

      ADOQuery7.SQL.Clear ;
      ADOquery7.SQL.add('delete from protekt') ;
      ADOquery7.execSQL ;

      ADOQuery7.SQL.Clear ;
      ADOquery7.SQL.add('select * from protekt') ;
      AdoQuery7.Open;
      for ii  := 0 to slist.count-1 do        // po vseh kombinacijah plošče in šamota
      begin
        ProgUpdate(tx,slist.Count) ;
        p1 := slist[ii] ;
        ix := p1^.kolic - p1^.zal ;
        sleep(100) ;
        ZapisPro(p1^.linija,p1^.mat,p1^.mat_pl,p1^.naziv,p1^.kolic,p1^.zal,ix) ;
      end ;
      AdoQuery7.Close ;
    end;
    3 :
    begin                                      // sponke
      ADOQuery8.SQL.Clear ;
      ADOquery8.SQL.add('delete from sponke') ;
      ADOquery8.execSQL ;

      ADOQuery8.SQL.Clear ;
      ADOquery8.SQL.add('select * from sponke') ;
      AdoQuery8.Open;
      for ii  := 0 to slist.count-1 do        // po vseh kombinacijah plošče in sponk
      begin
        ProgUpdate(tx,slist.Count) ;
        p1 := slist[ii] ;
        ix := p1^.kolic - p1^.zal ;
        sleep(100) ;
        ZapisSpo(p1^.linija,p1^.mat,p1^.mat_pl,p1^.naziv,p1^.kolic,p1^.zal,ix) ;
      end ;
      AdoQuery8.Close ;
    end;

    4 :                                        // ulitki
    begin
      ADOQuery9.SQL.Clear ;
      ADOquery9.SQL.add('delete from ulitki') ;
      ADOquery9.execSQL ;

      ADOQuery9.SQL.Clear ;
      ADOquery9.SQL.add('select * from ulitki') ;
      AdoQuery9.Open;
      for ii  := 0 to slist.count-1 do        // po vseh kombinacijah plošče in ulitkov
      begin
        ProgUpdate(tx,slist.Count) ;
        p1 := slist[ii] ;
        ix := p1^.kolic - p1^.zal ;
        sleep(100) ;
        ZapisUli(p1^.iprem,p1^.linija,p1^.mat,p1^.mat_pl,p1^.naziv,p1^.kolic,p1^.zal,ix) ;
      end ;
      AdoQuery9.Close ;
    end;

    5 :                                        // spirale
    begin
      ADOQuery10.SQL.Clear ;
      ADOquery10.SQL.add('delete from spirale') ;
      ADOquery10.execSQL ;

      ADOQuery10.SQL.Clear ;
      ADOquery10.SQL.add('select * from spirale') ;
      AdoQuery10.Open;
      Fstroji.nanul ;
      for ii  := 0 to slist.count-1 do        // po vseh kombinacijah plošče in špirale
      begin
        ProgUpdate(tx,slist.Count) ;
        p1 := slist[ii] ;
        ix := p1^.kolic - p1^.zal ;
        sleep(100) ;
        ids := GetStrojSpir(p1^.nalog) ;
        ZapisSpi(p1^.iprem,p1^.linija,p1^.mat,p1^.mat_pl,p1^.naziv,p1^.kolic,p1^.zal,ix,ids) ;
        Fstroji.povecaj(ids,p1^.kolic) ;
      end ;
      AdoQuery9.Close ;
    end;


    6 :                                                 // obroči
    begin
      ADOQuery8.SQL.Clear ;
      ADOquery8.SQL.add('delete from obroci') ;
      ADOquery8.execSQL ;

      ADOQuery8.SQL.Clear ;
      ADOquery8.SQL.add('select * from obroci') ;
      AdoQuery8.Open;
      dd := Date ;
      for ii  := 0 to slist.count-1 do        // po vseh kombinacijah plošče in obročev
      begin
        ProgUpdate(tx,slist.Count) ;
        p1 := slist[ii] ;
        zlx := p1^.zal ; ;
        ix := p1^.kolic - zlx ;
    
        ZapisSpo(p1^.linija,p1^.mat,p1^.mat_pl,p1^.naziv,p1^.kolic,zlx,ix) ;
        AdoQuery8.edit ;
        adoQuery8.Fieldbyname('zap').value := p1^.iprem ;
        AdoQuery8.post ;
      end ;
      AdoQuery8.Close ;
    end;
  end;
end ;

