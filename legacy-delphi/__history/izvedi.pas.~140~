function CompareSam(pt1,pt2 : pointt) : Integer ;
begin
  if pt1^.iprem = pt2^.iprem  then
  begin
    if pt1^.ipl = pt2^.ipl  then result := 0
      else if  pt1^.ipl > pt2^.ipl then result := 1
                                     else result := -1
  end
    else if  pt1^.iprem > pt2^.iprem then result := 1
                                 else result := -1
end ;

