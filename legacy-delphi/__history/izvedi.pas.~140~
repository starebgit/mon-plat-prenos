// procedura za branje delovnih nalogov
Procedure Tprenos.GetProdList(id : integer; deln : string ; var tab : variant; var vredu : boolean) ;
  var funct : variant ;
begin
    Fizvedi.SAPFunctions1.Connection := Idispatch(Connection);
    funct := Fizvedi.sapFunctions1.add('BAPI_PRODORD_GET_LIST');

    funct.TABLES.item('PRODPLANT_RANGE').appendRow.Value('SIGN') := 'I' ;
    funct.TABLES.item('PRODPLANT_RANGE').Value(1,2) := 'EQ' ;
    funct.TABLES.item('PRODPLANT_RANGE').Value(1,3) := '0401' ;


    funct.TABLES.item('PROD_SCHED_RANGE').appendRow.Value('SIGN') := 'I' ;
    funct.TABLES.item('PROD_SCHED_RANGE').Value(1,2) := 'EQ' ;
    funct.TABLES.item('PROD_SCHED_RANGE').Value(1,3) := '200' ;

    if id = 1  then        // delovni nalogi za plošče
    begin
      funct.TABLES.item('ORDER_NUMBER_RANGE').appendRow.Value('SIGN') := 'I' ;
      funct.TABLES.item('ORDER_NUMBER_RANGE').Value(1,2) := 'GE' ;
      funct.TABLES.item('ORDER_NUMBER_RANGE').Value(1,3) := deln ;

      // s to omejitvijo definiram plošče
      funct.TABLES.item('MATERIAL_RANGE').appendRow.Value('SIGN') := 'I' ;
      funct.TABLES.item('MATERIAL_RANGE').Value(1,2) := 'EQ' ;
      funct.TABLES.item('MATERIAL_RANGE').Value(1,3) := '000012080000000000' ;
     // funct.TABLES.item('MATERIAL_RANGE').Value(1,4) := '000013789000000000' ;
      funct.TABLES.item('MATERIAL_RANGE').Value(1,4) := '000019789000000000' ;
    end ;
    if id = 2  then            // delovni nalogi za šamote in sponke
    begin
      funct.TABLES.item('MATERIAL_RANGE').appendRow.Value('SIGN') := 'I' ;
      funct.TABLES.item('MATERIAL_RANGE').Value(1,2) := 'EQ' ;
      funct.TABLES.item('MATERIAL_RANGE').Value(1,3) := deln ;
    end ;

    vredu := true ;
    if not funct.call then           // če ni bilo v redu
       vredu := false
    else
       tab := funct.TABLES.item('ORDER_HEADER');    // tabela nalogov
end ;

