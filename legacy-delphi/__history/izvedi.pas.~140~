procedure Tprenos.Obdelajsamot(nzz,mt,kodpl : string; ix,ln : longint; idc : integer; zlist,slist : Tlist) ;
  var nz,statdn,delns,mat : string ;
      kk,k1,k2,m,i : Integer ;
      bsam,vredu : boolean ;
      taba,funct,tabs : variant ;
      yi1,yi2,yie,rz,tt : longint ;
      fdate : Tdatetime ;
      st_potr,arbid : string;
begin
   nz := StringReplace(nzz,'Plo##a #amot','Plošča šamot',[]) ;
   kk := 4 ;
   if pos('šamot 220',nz) > 0 then kk := 1  ;
   if pos('šamot 180',nz) > 0 then kk := 2  ;
   if pos('šamot 145',nz) > 0 then kk := 3  ;
   if pos('šamot 80',nz) > 0 then kk := 4   ;
   if pos('šamot 110',nz) > 0 then kk := 4  ;
   if pos('šamot 115',nz) > 0 then kk := 4  ;

  // mat := KodaConv(mt,'O') ;
   mat := KodaForm(mt,SL,false) ;
   // poiščem delovne naloge šamotov
   Fizvedi.sapFunctions1.RemoveAll ;
   bsam := preveriSam(mt,zlist) ;
   // če šamot še ni bil obdelan
   if bsam then
   begin
      tt := GettickCount ;
      GetProdList(2,mt,taba,vredu) ;   // lista delovnih nalogov za šamot
     // showmessage(intTostr(Gettickcount -tt)) ;
      if not vredu then
      begin
        showMessage('Napaka bri branju proizvidnjih nalogov') ;
        exit
      end ;

      k1 := Taba.rowCount ;
      yi1 := 0 ;
      yi2 := 0 ;
      for i := 1 to k1 do       // po vseh nalogih za določen šamot
      begin
         delns := taba.value(i,1) ;


         try
            fdate := StrTodate(taba.value(i,10)) ;
         except
            fdate := date - 20
         end;


         // omejim se na tiste naloge ki niso starejši kot 20 dni
        // if fdate < date-20  then continue ;

         // izločim še zaključene
         try
           statdn := copy(taba.value(i,42),1,4) ;
         except
           statdn := 'TEHZ'
         end;

         tt := gettickCount ;
         if i = k1 then obdelajUli(delns,mat,ix,ln,idc,kk) ;
       //  showmessage('a'+intTostr(Gettickcount -tt)) ;

         if statdn = 'TEHZ' then continue ;

         // preberem potrditve za določen nalog

         Fizvedi.SAPFunctions1.Connection := Idispatch(Connection);
         funct := Fizvedi.sapFunctions1.add('ZETA_RFC_READ_AFRU');
         Funct.EXPORTS('dday').VALUE := fdate ;
         Funct.EXPORTS('stnal').VALUE := delns;
         funct.call ;           // če ni bilo v redu

         // računam donose na dveh različnih operacijah
         tabs := funct.TABLES.item('IT_AFRU');    // tabela rezultatov
         k2 := Tabs.rowCount ;
         for m := 1 to k2 do
         begin
            arbid := Tabs.value(m,9) ;
            st_potr := tabs.value(m,2) ;
            if (arbid >= '10004712') and (arbid <= '10004720')  then
            begin
               yie :=  Tabs.value(m,38);
               if Tabs.value(m,95) = 'X' then yie := -yie ;
               if (arbid >= '10004712') and (arbid <= '10004718')  then yi1 := yi1 + yie;
               if (arbid = '10004720') or (arbid = '10004719') then yi2 := yi2 + yie;
            end;
         end ;
        // obdelajUli(delns,mat,ix,ln,idc) ;
       end;   // konec pregled nalogov šamotov
       rz := yi1 - yi2 ;      // razlika donosov dveh operacijah
       //  mat := KodaConv(mt,'O') ;
       ZapisSk(mat,ix,rz,zlist) ;
    end else ZapisSup(mat,ix,sulist) ;

  //  mat := KodaConv(mt,'O') ;
    ZapisSam(kk,idc,ln,mat,kodpl,nz,ix,slist) ;
end ;

