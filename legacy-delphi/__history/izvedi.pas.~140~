Procedure Tprenos.Zapissam(kk,idc,ln : integer ;mt,kodpl,nz : string; ix : longint; var slist: tlist) ;
  var ii : integer ;
      nas : boolean ;
      pp : ^sams ;
begin
  nas := false ;
  for ii  := 0 to slist.count-1 do
  begin
    pp := slist[ii] ;
    if (pp.mat = mt) and (pp.mat_pl = kodpl) then
    begin
      nas := true ;
      pp^.kolic := pp^.kolic + ix ;
      break
    end;
  end;
  if not nas then
  begin
    new(pp) ;
    pp^.iprem := kk ;
    pp^.ipl := idc ;
    pp^.linija := ln ;
    pp^.mat := mt ;
    pp^.mat_pl := kodpl ;
    pp^.naziv := nz ;
    pp^.kolic := ix ;
    pp^.pec := 0 ;
  //  pp^.razl := rz ;
    slist.add(pp)
  end;
end;

