Procedure Tprenos.ListaPrek(var list : Tlist) ;
  var ii : Integer ;
      prvic : boolean ;
      pp : ^prrk ;
begin
  Fizvedi.ADOQuery5.SQL.Clear ;
  Fizvedi.ADOquery5.SQL.add('select * from prekinitve') ;
  Fizvedi.AdoQuery5.Open;
  Fizvedi.AdoQuery5.First ;
  while not Fizvedi.AdoQuery5.eof  do
  begin
    if Fizvedi.AdoQuery5.Fieldbyname('dan').value >= date then
    begin
      prvic := true ;
      for ii := 0 to list.count-1 do
      begin
        pp := list[ii] ;
        if (pp^.dt = Fizvedi.AdoQuery5.Fieldbyname('dan').value) and (pp^.trak = Fizvedi.AdoQuery5.Fieldbyname('trak').value) and (pp^.izmena = Fizvedi.AdoQuery5.Fieldbyname('izmena').value) then
        begin
          prvic := false ;
          pp^.stev :=  pp^.stev + (1 shl Fizvedi.AdoQuery5.Fieldbyname('ura').value)
        end;
      end;
      if prvic then
      begin
        new(pp) ;
        pp^.dt := Fizvedi.AdoQuery5.Fieldbyname('dan').value ;
        pp^.izmena := Fizvedi.AdoQuery5.Fieldbyname('trak').value ;
        pp^.trak := Fizvedi.AdoQuery5.Fieldbyname('izmena').value ;
        pp^.stev := (1 shl Fizvedi.AdoQuery5.Fieldbyname('ura').value) ;
        list.Add(pp) ;
      end;
    end;
    Fizvedi.AdoQuery5.next ;
  end;
  Fizvedi.AdoQuery5.Close ;
end;

