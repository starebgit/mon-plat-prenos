Procedure Tprenos.execute ;
 var deln,sx, statdn,kdd : string ;
     order,pkod,conf,conf_c,mat,dm : string ;
     dn,kodpl,nzp,nzs,mt,nzz,mtp,mts,dir,mto,nzo,pzz : string ;
     vredu,bkod : boolean ;
     tab,tabc,tabs : variant ;
     ist,kk,izap,i,j,m,mm,ni : Integer ;
     ikolic,potr,yie,yield : Integer ;
     mk,ln,idc,ix,ii,kks : integer ;
     slist,zlist,splist,zplist,sslist,zslist,solist,zolist : Tlist ;
     ff : textfile ;
     tt : longint ;
     dstart : TdateTime ;
begin
  fizvedi.AdoQuery2.Connection := fIzvedi.AdoConnection1  ;
  try
    Fizvedi.ADOQuery2.SQL.Clear ;
    Fizvedi.ADOquery2.SQL.add('select * from plosce') ;
    Fizvedi.AdoQuery2.Open;
    Fizvedi.AdoQuery2.first;
    deln := Fizvedi.AdoQuery2nalog.value ;
    Fizvedi.AdoQuery2.Close ;
  except
     deln := '000004283286' ;
  end;
  deln := '000005223286' ;
  Fzacetek.label2.Caption := 'Začetni delovni nalog ' + deln ;

  tt := GetTickCount ;
  Screen.Cursor := crHourGlass ;


  //Fizvedi.AdoQuery2.delete ;

  Prijava ;
  if Connection.LogOn(0,true) = true then  (* parameter "true" = SilentLogOn *)
  begin
    Fizvedi.ADOQuery2.SQL.Clear ;
    Fizvedi.ADOquery2.SQL.add('delete from plosce') ;
    Fizvedi.ADOquery2.execSQL ;
    sleep(500) ;

    Fizvedi.ADOQuery2.SQL.Clear ;
    Fizvedi.ADOquery2.SQL.add('select * from plosce') ;
    Fizvedi.AdoQuery2.Open;

        // preberem listo delovnih nalogov za plošče
    GetProdList(1,deln,tab,vredu ) ;
    if not vredu then
    begin
       showMessage('Napaka bri branju proizvidnjih nalogov') ;
       exit
    end ;

    kk := Tab.rowCount ;
    sx := 'Prenos plošč ' ;
    Fzacetek.Progressbar1.Min := 0 ;
    Fzacetek.Progressbar1.Max := kk ;
    Fzacetek.ProgressBar1.Position := 0;
    Fzacetek.ProgressBar1.Step := 1;
    Fzacetek.label1.Caption := sx + '1/'+IntTostr(kk) ;
    Fzacetek.label1.Update ;

    izap := 1 ;

    for i := 1 to kk do           // po vseh delovnih nalogin za plošče
    begin
       if terminated then exit  ;

       Fzacetek.ProgressBar1.StepIt;
       Fzacetek.label1.Caption := sx + IntTostr(Fzacetek.Progressbar1.position) + '/' + IntTostr(kk) ;
       Fzacetek.label1.Update ;

       // tehnično zaključene izločim
       statdn := copy(tab.value(i,42),1,4) ;
       if (statdn = 'TEHZ') or (statdn = 'ZAKL') then continue ;

       // izločim naloge ki ne pripadajo ploščam
       kdd := tab.value(i,5) ;
       if (kdd[9] <> '4') and (kdd[9] <> '3') and (kdd[9] <> '2') then continue ;

       // preberem( podatke iz delovnega naloga
       GetProdDetail(tab.value(i,1),4,tabc,vredu) ;
       if not vredu then
       begin
         showMessage('Napaka bri branju enega proizvodnjega naloga') ;
         exit
       end ;

       ikolic := 0 ;
       potr :=  Round(Tab.value(i,18)) ;
       order := Tab.value(i,1) ;
       dstart := Tab.value(i,14) ;
      // Showmessage(IntTostr(i) + '/' + IntTostr(tabc.rowcount)) ;
       for j := 1 to tabc.rowCount do        // po vseh operacijah
       begin
          pkod := tabc.value[j,12] ;
          bkod := (pkod = 'PP04') or (pkod = 'PP14') or (pkod = 'PP02') or (pkod = 'PP10') ;
          if bkod and (tabc.value[j,25] > 0) and (tabc.value[j,11] = '0010') then
          begin
            conf := Tabc.value(j,4) ;
            // tt := GetTickCount ;
            // za vsako operacijo preberem potrditve
            GetConfList(order,conf,tabs,vredu) ;
            if not vredu then
            begin
              showMessage('Napaka bri branju list potrditev') ;
              exit
            end ;

            // računanje donosa
            yield := 0 ;
            mm := tabs.rowcount ;
            for m := 1 to mm do
            begin
               conf_c := tabs.value(m,2) ;
               //tt := GettickCount ;
               GetConfDetail(conf,conf_c,yie) ;
               yield := yield + yie;
            end;

            ikolic := potr-yield ;
            if ikolic > 0 then
            begin
              dm := Tabc.value(j,43) ;
              ist := Fizvedi.Traks.IndexOf(dm) +1 ;
             // mat := KodaConv(tab.value(i,5),'O') ;
              mat := KodaForm(tab.value(i,5),SL,false) ;
              Fizvedi.ZapisPlo(izap,ist,ikolic,order,mat,dstart);
              Inc(izap) ;
           end;
         end;
       end;
     for j := 1 to tabc.rowCount do tabc.DeleteRow ;
    end ;      // konec pregled pa vseh nalogih
  end ;
  Fizvedi.AdoQuery2.Close ;
  Fizvedi.traks.free ;
  slist := Tlist.create    ;
  zlist := Tlist.create    ;
  splist := Tlist.create    ;
  zplist := Tlist.create    ;
  sslist := Tlist.create    ;
  zslist := Tlist.create    ;
  sulist := Tlist.create    ;
  zulist := Tlist.create    ;
  svlist := Tlist.create    ;
  zolist := Tlist.create    ;
  solist := Tlist.create    ;
  //zvlist := Tlist.create    ;
  Prijava ;
  Fizvedi.ADOtable1.Open ;
  Fizvedi.ADOQuery2.Open ;

