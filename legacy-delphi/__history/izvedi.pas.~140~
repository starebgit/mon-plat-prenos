Procedure Tprenos.zaloge_sp(slist,svlist: Tlist) ;
var
  i,nas,k: Integer;
  kl,zl1,zl2,zl3,pl1,pl2,pl3,rz : longint ;
  kdsm,kd1,kd2,kd3,nz1,nz2,nz3,tx  : string ;
  p1,pp : ^sams ;

  procedure urediSp(kd,nz : string; zl : longint) ;
    var pl : longint ;
        j : Integer ;
        mtt : string ;
  begin
     if kl < zl  then
     begin
        zl := zl-kl ;
        pl := kl ;
     end else
     begin
        pl := zl ;
        zl := 0 ;
     end ;
     rz := kl -pl ;
    // mtt := KodaConv(kd,'O') ;
     mtt := KodaForm(kd,SL,false) ;
     //form1.ADOtable10.AppendRecord([p1^.ipl,p1^.iprem,p1^.linija,mtt,kdsm,nz,kl,pl,rz]) ;
     Fizvedi.ZapisSpi(p1^.iprem,p1^.linija,mtt,kdsm,nz,kl,pl,rz) ;
     for j := 1 to svlist.count-1 do
     begin
        pp := svlist[j] ;
        if pp^.mat = kd then pp^.zal := zl ;
        break
     end;
  end ;

begin
  Fizvedi.ADOQuery10.SQL.Clear ;
  Fizvedi.ADOquery10.SQL.add('delete from spirale') ;
  Fizvedi.ADOquery10.execSQL ;

  Fizvedi.ADOQuery10.SQL.Clear ;
  Fizvedi.ADOquery10.SQL.add('select * from spirale') ;
  Fizvedi.AdoQuery10.Open;
  tx := 'Prenos zalog A ' ;
  for i := 1 to svlist.count-1 do
  begin
     pp := svlist[i] ;
     pp^.zal := ZalogeZaMat(pp^.mat) ;
  end;

  Fzacetek.Progressbar1.BarColor := clBlue ;
  Fzacetek.Progressbar1.Min := 0 ;
  Fzacetek.Progressbar1.Max := slist.Count ;
  Fzacetek.ProgressBar1.Position := 0;
  Fzacetek.ProgressBar1.Step := 1;
  Fzacetek.ProgressBar1.Update ;
  Fzacetek.label1.Caption := tx + '1/'+IntTostr(slist.Count) ;
  Fzacetek.label1.Update ;

  for i := 0 to slist.count-1 do
  begin
     Fzacetek.ProgressBar1.StepIt;
     Fzacetek.ProgressBar1.Update;
     Fzacetek.label1.Caption := tx + IntTostr(Fzacetek.Progressbar1.position) + '/' + IntTostr(slist.count) ;
     Fzacetek.label1.Update ;

     p1 := slist[i] ;
     kdsm := p1^.mat ;
     kl := p1^.kolic ;
     k := 0 ;
     nas := 0 ;
     kd1 := '' ;
     kd2 := '' ;
     kd3 := '' ;
     while (k < svlist.count) and (nas < 3) do
     begin
        pp := svlist[k] ;
        if kdsm = pp^.mat_pl then
        begin
          case nas of
            0 : begin
              kd1 := pp^.mat ;
              nz1 := pp^.naziv ;
              zl1 := pp^.zal ;
              inc(nas)
            end;
            1 : begin
              kd2 := pp^.mat ;
              nz2 := pp^.naziv ;
              zl2 := pp^.zal ;
              inc(nas)
            end;
            2 : begin
              kd3 := pp^.mat ;
              nz3 := pp^.naziv ;
              zl3 := pp^.zal ;
              inc(nas)
            end;
          end;
        end;
        inc(k) ;
     end ;

     if kd1 <> '' then urediSp(kd1,nz1,zl1) ;
     if kd2 <> '' then urediSp(kd2,nz2,zl2) ;
     if kd3 <> '' then urediSp(kd3,nz3,zl3) ;
  end;
  Fizvedi.AdoQuery10.Close ;
end;



